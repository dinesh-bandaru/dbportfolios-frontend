function bestCurrencyOption(symbol: string): string {
    const opts = ["₹","$","€","£","A$"];
    if (opts.includes(symbol)) return symbol;
    if (GEO.currency === "EUR") return "€";
    if (["CAD","NZD","SGD","HKD","USD","MXN","ARS","CLP","COP"].includes(GEO.currency)) return "$";
    if (GEO.currency === "GBP") return "£";
    if (GEO.currency === "AUD") return "A$";
    return "$";
}

function lfSetCurrency(value: string) {
    const opt = document.querySelector(`.lf-curr-opt[data-value="${CSS.escape(value)}"]`) as HTMLElement | null;
    if (!opt) return;
    const flagEl  = document.getElementById("lf-curr-flag");
    const labelEl = document.getElementById("lf-curr-label");
    if (flagEl)  flagEl.textContent  = opt.dataset.flag  ?? "";
    if (labelEl) labelEl.textContent = opt.dataset.label ?? value;
    document.getElementById("lf-curr-btn")?.setAttribute("aria-expanded","false");
    document.getElementById("lf-curr-menu")?.classList.remove("lf-curr-menu--open");
    document.querySelectorAll(".lf-curr-opt").forEach(el => el.classList.remove("lf-curr-opt--active"));
    opt.classList.add("lf-curr-opt--active");
}
document.getElementById("lf-curr-btn")?.addEventListener("click", () => {
    const menu = document.getElementById("lf-curr-menu");
    const btn  = document.getElementById("lf-curr-btn");
    const open = menu?.classList.toggle("lf-curr-menu--open");
    btn?.setAttribute("aria-expanded", String(open));
});
document.querySelectorAll(".lf-curr-opt").forEach(opt => {
    opt.addEventListener("click", () => {
        lfSetCurrency((opt as HTMLElement).dataset.value ?? "$");
        document.getElementById("lf-curr-menu")?.classList.remove("lf-curr-menu--open");
    });
});
document.addEventListener("click", e => {
