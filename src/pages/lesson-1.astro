    if (wrap && !wrap.contains(e.target as Node)) {
        document.getElementById("lf-curr-menu")?.classList.remove("lf-curr-menu--open");
        document.getElementById("lf-curr-btn")?.setAttribute("aria-expanded","false");
    }
});
