---
import Layout from "../layouts/Layout.astro";
import BrandLogo from "../components/BrandLogo.astro";
---

<Layout title="Lesson 1 — The Invisible Tax | DB Portfolios">
<div id="auth-checker" style="display:none;">

<!-- ── NAV ── -->
<nav class="lesson-nav">
    <div class="nav-inner">
        <a href="/dashboard" class="nav-back">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            Dashboard
        </a>
        <a href="/dashboard" class="nav-logo"><BrandLogo width="120" height="20" color="#ffffff" /></a>
        <div class="nav-progress-wrap">
            <span id="slide-counter">1 / 5</span>
            <div class="nav-prog-bar"><div class="nav-prog-fill" id="nav-fill"></div></div>
        </div>
    </div>
</nav>

<main class="stage">
<div class="slides-wrap" id="slides-wrap">

<!-- ════════════════════════════════════════════
     SLIDE 1 — AI Time Machine
     Hook: prices have outrun your savings.
     ════════════════════════════════════════════ -->
<div class="slide active" data-slide="0">
    <div class="slide-inner">
        <span class="slide-tag">The Invisible Tax</span>
        <h1 class="slide-h1">The Cost of <span class="grad-red">Doing Nothing</span></h1>
        <p class="slide-body">Think of something you wanted to buy a few years ago. Type it in — we'll look up what it actually cost then, and what it costs today.</p>

        <div class="time-machine">
            <h3 class="tm-title">🕰️ Financial Time Machine</h3>
            <p class="tm-sub">Enter any item (e.g. "Honda Activa", "iPhone", "1 kg rice") and the year you remember wanting it.</p>
            <div class="tm-input-row">
                <div class="tm-input-group">
                    <label for="tm-item-input">What did you want to buy?</label>
                    <input type="text" id="tm-item-input" class="tm-text-input" placeholder="e.g. Royal Enfield Bullet 350" maxlength="80" autocomplete="off" spellcheck="false" />
                </div>
                <div class="tm-input-group tm-input-year">
                    <label for="tm-year-input">Which year?</label>
                    <input type="number" id="tm-year-input" class="tm-text-input" placeholder="e.g. 2015" min="2000" max="2023" value="2015" />
                </div>
                <button id="tm-lookup-btn" class="tm-btn" aria-label="Look up price">
                    <span id="tm-btn-text">Look it up →</span>
                </button>
            </div>
            <div id="tm-log-panel" class="tm-log-panel" style="display:none;">
                <div class="tm-log-header">
                    <span class="tm-log-dot"></span>
                    <span class="tm-log-title">Researching…</span>
                </div>
                <div id="tm-log-lines" class="tm-log-lines"></div>
            </div>
            <div id="tm-results" class="tm-results" style="display:none;">
                <div class="tm-card tm-price">
                    <div class="tm-c-head">🛒 Then vs Now</div>
                    <div class="tm-c-vs">
                        <div>
                            <small id="tm-year-label">Then</small>
                            <div class="tm-item-name" id="tm-past-item"></div>
                            <div class="tm-val" id="val-past-price">—</div>
                        </div>
                        <div class="tm-arrow">→</div>
                        <div>
                            <small>Now</small>
                            <div class="tm-item-name" id="tm-now-item"></div>
                            <div class="tm-val grad-red" id="val-now-price">—</div>
                        </div>
                    </div>
                    <div class="tm-c-badge" id="badge-price"></div>
                </div>
                <div class="tm-card tm-insight">
                    <div class="tm-c-head">💡 What this means</div>
                    <p id="tm-insight-text" class="tm-insight-body"></p>
                    <div class="tm-sources" id="tm-sources"></div>
                </div>
            </div>
        </div>

        <div class="callout callout-red" id="tm-conclusion">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p>Notice the gap? <strong>Prices grow much faster than salaries.</strong> Money sitting still is money slowly losing value — every single year.</p>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════
     SLIDE 2 — Lifestyle Inflation Arc
     Show how costs stack up faster than raises.
     ════════════════════════════════════════════ -->
<div class="slide lf-slide" data-slide="1">
    <div class="lf-layout">
        <div class="lf-left">
            <span class="slide-tag">Lifestyle Inflation</span>
            <h2 class="slide-h2" style="font-size:1.3rem;margin:0.25rem 0 0.5rem;">Life gets richer.<br><span class="grad-red">So do the bills.</span></h2>

            <div class="lf-control-bar">
                <div class="lf-curr-wrap" id="lf-curr-wrap">
                    <button class="lf-curr-btn" id="lf-curr-btn" type="button" aria-haspopup="listbox" aria-expanded="false">
                        <span class="lf-curr-flag" id="lf-curr-flag">🇮🇳</span>
                        <span class="lf-curr-label" id="lf-curr-label">INR ₹</span>
                        <svg class="lf-curr-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <ul class="lf-curr-menu" id="lf-curr-menu" role="listbox" aria-label="Currency">
                        <li class="lf-curr-opt" data-value="₹"  data-flag="🇮🇳" data-label="INR ₹" role="option"><span class="lf-curr-opt-flag">🇮🇳</span><span class="lf-curr-opt-name">INR</span><span class="lf-curr-opt-sym">₹</span></li>
                        <li class="lf-curr-opt" data-value="$"  data-flag="🇺🇸" data-label="USD $" role="option"><span class="lf-curr-opt-flag">🇺🇸</span><span class="lf-curr-opt-name">USD</span><span class="lf-curr-opt-sym">$</span></li>
                        <li class="lf-curr-opt" data-value="€"  data-flag="🇪🇺" data-label="EUR €" role="option"><span class="lf-curr-opt-flag">🇪🇺</span><span class="lf-curr-opt-name">EUR</span><span class="lf-curr-opt-sym">€</span></li>
                        <li class="lf-curr-opt" data-value="£"  data-flag="🇬🇧" data-label="GBP £" role="option"><span class="lf-curr-opt-flag">🇬🇧</span><span class="lf-curr-opt-name">GBP</span><span class="lf-curr-opt-sym">£</span></li>
                        <li class="lf-curr-opt" data-value="A$" data-flag="🇦🇺" data-label="AUD A$" role="option"><span class="lf-curr-opt-flag">🇦🇺</span><span class="lf-curr-opt-name">AUD</span><span class="lf-curr-opt-sym">A$</span></li>
                    </ul>
                </div>
                <div class="lf-control-divider"></div>
                <input type="number" id="lf-salary" class="lf-salary-input" value="1200000" min="10000" />
                <button class="lf-apply-btn" id="lf-apply-btn">Apply</button>
            </div>

            <div class="lf-scrubber-block">
                <div class="lf-scrubber-header">
                    <span class="lf-scrubber-title">Drag through your life</span>
                    <span class="lf-year-badge" id="lf-year-badge">Today</span>
                </div>
                <input type="range" id="lf-scrubber" class="lf-scrubber" min="0" max="20" step="1" value="0" />
                <div class="lf-scrubber-ends"><span>Today</span><span>Year 20</span></div>
                <div class="lf-stage-pips">
                    <span class="lf-pip" style="left:0%"  title="Single">🧍</span>
                    <span class="lf-pip" style="left:20%" title="Relationship">💑</span>
                    <span class="lf-pip" style="left:40%" title="Married">💍</span>
                    <span class="lf-pip" style="left:60%" title="Young Family">👶</span>
                    <span class="lf-pip" style="left:85%" title="Full Family">👨‍👩‍👧‍👦</span>
                </div>
            </div>

            <div class="lf-stage-banner" id="lf-stage-banner">
                <span class="lf-stage-icon" id="lf-stage-icon">🧍</span>
                <div class="lf-stage-text">
                    <span class="lf-stage-name" id="lf-stage-name">Single &amp; Starting Out</span>
                    <span class="lf-stage-desc" id="lf-stage-desc">Freedom, few expenses. The world feels wide open.</span>
                </div>
            </div>

            <div class="lf-stats-bar">
                <div class="lf-stat">
                    <span class="lf-stat-label">Annual Income</span>
                    <span class="lf-stat-val lf-green" id="lf-salary-disp">—</span>
                </div>
                <div class="lf-stat">
                    <span class="lf-stat-label">Monthly</span>
                    <span class="lf-stat-val" id="lf-monthly-disp">—</span>
                </div>
                <div class="lf-stat">
                    <span class="lf-stat-label">Out of reach</span>
                    <span class="lf-stat-val lf-stat-red" id="lf-red-count">0</span>
                </div>
            </div>

            <div class="callout callout-amber" id="lf-callout" style="display:none;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <p id="lf-callout-text" style="font-size:0.78rem;margin:0;"></p>
            </div>
        </div>

        <div class="lf-right">
            <div class="lf-table-wrap">
                <table class="lf-table">
                    <thead>
                        <tr>
                            <th class="lf-th lf-th-item">Expense</th>
                            <th class="lf-th lf-th-price">Cost / mo</th>
                            <th class="lf-th lf-th-pct">% salary</th>
                            <th class="lf-th lf-th-dot"></th>
                        </tr>
                    </thead>
                    <tbody id="lf-tbody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════
     SLIDE 3 — Interactive FD Waterfall
     What the bank advertises vs what you keep.
     Replaces old static version.
     ════════════════════════════════════════════ -->
<div class="slide" data-slide="2">
    <div class="slide-inner">
        <span class="slide-tag">The FD Illusion</span>
        <h2 class="slide-h2">Where Does Your FD Return Go?</h2>
        <p class="slide-sub">Two silent drains eat almost everything the bank advertises. Adjust the sliders to see your real situation.</p>

        <div class="wf-interactive">
            <div class="wf-controls">
                <div class="wf-ctrl">
                    <label class="wf-ctrl-label">FD Nominal Rate: <strong id="wf-fd-disp">7.0%</strong></label>
                    <input type="range" id="wf-fd" class="generic-slider" min="3" max="12" step="0.5" value="7" />
                </div>
                <div class="wf-ctrl">
                    <label class="wf-ctrl-label">Your Tax Rate: <strong id="wf-tax-disp">30%</strong></label>
                    <input type="range" id="wf-tax" class="generic-slider" min="0" max="45" step="5" value="30" />
                </div>
                <div class="wf-ctrl">
                    <label class="wf-ctrl-label">Inflation Rate: <strong id="wf-inf-disp">5.5%</strong></label>
                    <input type="range" id="wf-inf" class="generic-slider" min="1" max="15" step="0.5" value="5.5" />
                </div>
            </div>

            <div class="wf-bars">
                <div class="wf-step">
                    <div class="wf-step-label">Nominal FD Return</div>
                    <div class="wf-bar-track">
                        <div class="wf-bar wf-bar-blue" id="wfb-nominal" style="width:100%">
                            <span class="wf-bar-val" id="wfv-nominal">7.0%</span>
                        </div>
                    </div>
                </div>
                <div class="wf-drain-label" id="wf-drain-tax">↓ Tax (30%) eats −2.1%</div>
                <div class="wf-step">
                    <div class="wf-step-label">After-Tax Return</div>
                    <div class="wf-bar-track">
                        <div class="wf-bar wf-bar-amber" id="wfb-aftertax" style="width:70%">
                            <span class="wf-bar-val" id="wfv-aftertax">4.9%</span>
                        </div>
                        <div class="wf-bar-lost wf-bar-lost-tax" id="wfb-lost-tax" style="width:30%"></div>
                    </div>
                </div>
                <div class="wf-drain-label" id="wf-drain-inf">↓ Inflation (5.5%) burns −5.5%</div>
                <div class="wf-step">
                    <div class="wf-step-label">Real Return (Purchasing Power)</div>
                    <div class="wf-bar-track">
                        <div class="wf-bar wf-bar-real" id="wfb-real" style="width:13%">
                            <span class="wf-bar-val" id="wfv-real">0.9%</span>
                        </div>
                        <div class="wf-bar-lost wf-bar-lost-inf" id="wfb-lost-inf" style="width:87%"></div>
                    </div>
                </div>
            </div>

            <div class="wf-verdict" id="wf-verdict">
                <span class="wf-verdict-icon" id="wf-verdict-icon">⚠️</span>
                <span id="wf-verdict-text">Your FD real return is <strong id="wf-real-hl">0.9%</strong> — barely above zero. Inflation is winning.</span>
            </div>
        </div>

        <div class="two-col" style="margin-top:0.25rem;">
            <div class="info-panel panel-red">
                <h3>❌ The Treadmill</h3>
                <p>You lock up capital for years, pay tax on every rupee of interest, then watch inflation consume the rest. Maximum effort. Minimal progress.</p>
            </div>
            <div class="info-panel panel-green">
                <h3>✅ Real Safety</h3>
                <p>"Safe" means preserving purchasing power — not just avoiding a nominal loss. An FD that loses to inflation is losing real money, silently.</p>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════
     SLIDE 4 — Compounding
     The antidote: show what happens when you
     stop feeding the treadmill.
     ════════════════════════════════════════════ -->
<div class="slide" data-slide="3">
    <div class="slide-inner">
        <span class="slide-tag">The Escape Hatch</span>
        <h2 class="slide-h2">The Power of Compounding</h2>
        <p class="slide-sub">The antidote to the invisible tax. Reinvesting returns turns time into your greatest financial ally.</p>

        <div class="comp-visual" id="comp-visual"></div>

        <div class="calc-wrap">
            <div class="calc-row">
                <label for="comp-years">Years Invested</label>
                <div class="slider-row">
                    <input type="range" id="comp-years" min="1" max="30" step="1" value="10" />
                    <span id="comp-years-display" class="val-display">10 yrs</span>
                </div>
            </div>
            <div class="calc-row">
                <label for="comp-rate">Annual Return (%)</label>
                <div class="slider-row">
                    <input type="range" id="comp-rate" min="6" max="18" step="0.5" value="13.5" />
                    <span id="comp-rate-display" class="val-display">13.5%</span>
                </div>
            </div>
            <div class="calc-result">
                <div class="result-card result-good">
                    <span class="result-label" id="comp-base-label">100,000 grows to</span>
                    <span class="result-val" id="comp-result">—</span>
                </div>
                <div class="result-card result-good">
                    <span class="result-label">Total gain</span>
                    <span class="result-val" id="comp-gain">—</span>
                </div>
            </div>
        </div>

        <div class="hen-metaphor">
            <p class="meta-title">🐔 The Hen Metaphor</p>
            <p>You start with one hen. In year one it lays one egg. Instead of eating it, you hatch it into another hen — now <strong>two hens work for you.</strong> Each year both hens lay eggs, and you hatch every single one. Growth cascades exponentially.</p>
            <p>Eat every egg: 5 hens after 5 years. Reinvest every egg: <strong>11 hens.</strong> Same time. Completely different outcome.</p>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════
     SLIDE 5 — Pay Yourself First
     The one behavioural rule that makes it real.
     ════════════════════════════════════════════ -->
<div class="slide" data-slide="4">
    <div class="slide-inner">
        <span class="slide-tag">Your Action Plan</span>
        <h2 class="slide-h2">Pay Yourself First</h2>
        <p class="slide-sub">One habit separates people who build wealth from people who don't.</p>

        <div class="two-paths">
            <div class="path-card path-bad">
                <div class="path-header"><span class="path-emoji">❌</span><h3>Common Trap</h3></div>
                <div class="path-flow">
                    <div class="pf-step">Earn income</div>
                    <div class="pf-arrow">↓</div>
                    <div class="pf-step pf-highlight-red">Pay all lifestyle expenses first</div>
                    <div class="pf-arrow">↓</div>
                    <div class="pf-step pf-highlight-red">Save whatever is left — usually nothing</div>
                </div>
                <p class="path-result bad-result">No consistency → no compounding → no wealth</p>
            </div>
            <div class="path-card path-good">
                <div class="path-header"><span class="path-emoji">✅</span><h3>Wealth Path</h3></div>
                <div class="path-flow">
                    <div class="pf-step">Earn income</div>
                    <div class="pf-arrow">↓</div>
                    <div class="pf-step pf-highlight-green">Invest first — lock in returns immediately</div>
                    <div class="pf-arrow">↓</div>
                    <div class="pf-step pf-highlight-green">Live on what remains</div>
                </div>
                <p class="path-result good-result">Consistent compounding → growing secondary income → independence</p>
            </div>
        </div>

        <div class="callout callout-green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <p>How much you start with matters far less than <strong>starting at all.</strong> The invisible tax compounds against you every year you wait — so does compounding work <em>for</em> you, the earlier you begin.</p>
        </div>

        <div id="complete-banner" class="complete-banner" style="display:none;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Lesson 1 Complete — you understand the invisible tax.
        </div>
    </div>
</div>

</div><!-- /slides-wrap -->

<button class="nav-arrow prev" id="btn-prev" aria-label="Previous"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg></button>
<button class="nav-arrow next" id="btn-next" aria-label="Next"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></button>

<div class="dots" id="dots">
    <span class="dot active" data-i="0"></span>
    <span class="dot" data-i="1"></span>
    <span class="dot" data-i="2"></span>
    <span class="dot" data-i="3"></span>
    <span class="dot" data-i="4"></span>
</div>
</main>
</div><!-- /auth-checker -->

<script>
const token = localStorage.getItem("auth_token");
if (!token) { window.location.href = "/login"; }
else { (document.getElementById("auth-checker") as HTMLElement).style.display = "block"; }

declare global { interface Window { __GEO__: { country: string; currency: string; symbol: string; locale: string; timezone: string; city: string } } }
const GEO = window.__GEO__ ?? { country: "IN", currency: "INR", symbol: "₹", locale: "en-IN", timezone: "Asia/Kolkata", city: "Mumbai" };

/* ── Slide navigation ─────────────────────────────────────────────── */
const TOTAL = 5;
let current = 0;
const slides = document.querySelectorAll<HTMLElement>(".slide");
const dots   = document.querySelectorAll<HTMLElement>(".dot");
const counter = document.getElementById("slide-counter")!;
const navFill = document.getElementById("nav-fill")!;

function goTo(idx: number) {
    slides[current].classList.remove("active");
    dots[current].classList.remove("active");
    current = Math.max(0, Math.min(idx, TOTAL - 1));
    slides[current].classList.add("active");
    dots[current].classList.add("active");
    counter.textContent = `${current + 1} / ${TOTAL}`;
    navFill.style.width = `${((current + 1) / TOTAL) * 100}%`;
    (document.getElementById("btn-prev") as HTMLButtonElement).disabled = current === 0;
    if (current === 1) { slides[1].scrollTop = 0; if (lfRenderedIds.size === 0) lfBuildGrid(); }
    if (current === 2) updateWaterfall();
    if (current === 3) { updateComp(); renderHens(); }
    if (current === TOTAL - 1) {
        localStorage.setItem("lesson_1_done", "true");
        const banner = document.getElementById("complete-banner");
        if (banner) banner.style.display = "flex";
        const btn = document.getElementById("btn-next") as HTMLButtonElement;
        btn.title = "Next lesson";
        btn.onclick = () => { window.location.href = "/lesson-2"; };
    }
}

document.getElementById("btn-prev")?.addEventListener("click", () => goTo(current - 1));
document.getElementById("btn-next")?.addEventListener("click", () => { if (current < TOTAL - 1) goTo(current + 1); });
dots.forEach(d => d.addEventListener("click", () => goTo(Number(d.dataset.i))));
document.addEventListener("keydown", e => {
    if (e.key === "ArrowRight" || e.key === "ArrowDown") goTo(current + 1);
    if (e.key === "ArrowLeft"  || e.key === "ArrowUp")   goTo(current - 1);
});

/* ── Currency formatter ────────────────────────────────────────────── */
function fmt(n: number, sym?: string, country?: string): string {
    const s = sym ?? GEO.symbol;
    const c = country ?? GEO.country;
    const a = Math.round(Math.abs(n));
    if (c === "IN") {
        if (a >= 10000000) return s + (a / 10000000).toFixed(1) + "Cr";
        if (a >= 100000)   return s + (a / 100000).toFixed(1) + "L";
        if (a >= 1000)     return s + (a / 1000).toFixed(0) + "K";
        return s + a.toLocaleString("en-IN");
    }
    if (a >= 1000000) return s + (a / 1000000).toFixed(1) + "M";
    if (a >= 1000)    return s + (a / 1000).toFixed(0) + "K";
    return s + a.toLocaleString(GEO.locale);
}

/* ══════════════════════════════════════════════════
   SLIDE 1 — AI Financial Time Machine
   ══════════════════════════════════════════════════ */
const API_BASE = import.meta.env.DEV
    ? "http://localhost:8787"
    : "https://dbportfolios-backend.blr-bull.workers.dev";

const itemInput    = document.getElementById("tm-item-input")  as HTMLInputElement;
const yearInput    = document.getElementById("tm-year-input")  as HTMLInputElement;
const lookupBtn    = document.getElementById("tm-lookup-btn")  as HTMLButtonElement;
const btnText      = document.getElementById("tm-btn-text")!;
const logPanel     = document.getElementById("tm-log-panel")!;
const logLines     = document.getElementById("tm-log-lines")!;
const resultsEl    = document.getElementById("tm-results")!;
const yearLabel    = document.getElementById("tm-year-label")!;
const pastItemEl   = document.getElementById("tm-past-item")!;
const nowItemEl    = document.getElementById("tm-now-item")!;
const valPastP     = document.getElementById("val-past-price")!;
const valNowP      = document.getElementById("val-now-price")!;
const badgeP       = document.getElementById("badge-price")!;
const insightEl    = document.getElementById("tm-insight-text")!;
const sourcesEl    = document.getElementById("tm-sources")!;
const conclusionEl = document.getElementById("tm-conclusion")!;

function addLog(msg: string) {
    const line = document.createElement("div");
    line.className = "tm-log-line";
    line.textContent = "› " + msg;
    logLines.appendChild(line);
    logLines.scrollTop = logLines.scrollHeight;
}
function fmtPct(past: number, now: number): string {
    const pct = Math.round(((now - past) / past) * 100);
    return (pct >= 0 ? "+" : "") + pct + "%";
}

lookupBtn.addEventListener("click", async () => {
    const item = itemInput.value.trim();
    const year = yearInput.value.trim();
    if (!item) { itemInput.focus(); return; }
    if (!year || isNaN(Number(year))) { yearInput.focus(); return; }
    btnText.textContent = "Researching…";
    lookupBtn.disabled = true;
    logPanel.style.display = "block";
    resultsEl.style.display = "none";
    logLines.innerHTML = "";
    addLog(`Starting research for "${item}" (${year})…`);
    const tok = localStorage.getItem("auth_token") || "";
    try {
        const res = await fetch(`${API_BASE}/api/protected/course/price-lookup`, {
            method: "POST",
            headers: { "Content-Type": "application/json", Authorization: `Bearer ${tok}` },
            body: JSON.stringify({ item, year, country: GEO.country, currency: GEO.currency, city: GEO.city, timezone: GEO.timezone }),
        });
        if (!res.ok || !res.body) { addLog(`Error: ${res.status} ${res.statusText}`); return; }
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = ""; let streamDone = false;
        while (!streamDone) {
            const { done, value } = await reader.read();
            if (done) break;
            buffer += decoder.decode(value, { stream: true });
            const lines = buffer.split("\n");
            buffer = lines.pop() ?? "";
            for (const line of lines) {
                if (!line.startsWith("data:")) continue;
                const raw = line.slice(5).trim();
                if (raw === "[DONE]") { streamDone = true; break; }
                let evt: any; try { evt = JSON.parse(raw); } catch { continue; }
                if (evt.type === "log") { addLog(evt.message); }
                else if (evt.type === "result") {
                    yearLabel.textContent  = evt.year ?? year;
                    pastItemEl.textContent = evt.pastItem ?? item;
                    nowItemEl.textContent  = evt.nowItem ?? "Today's equivalent";
                    valPastP.textContent   = evt.pastPriceFormatted ?? `${GEO.symbol}${Number(evt.pastPrice).toLocaleString(GEO.locale)}`;
                    valNowP.textContent    = evt.nowPriceFormatted  ?? `${GEO.symbol}${Number(evt.nowPrice).toLocaleString(GEO.locale)}`;
                    badgeP.textContent     = fmtPct(Number(evt.pastPrice), Number(evt.nowPrice));
                    insightEl.textContent  = evt.insight ?? "";
                    sourcesEl.innerHTML = "";
                    const links: { url: string; title: string }[] = evt.sourceLinks ?? [];
                    if (links.length > 0) {
                        const lbl = document.createElement("span"); lbl.className = "tm-sources-label"; lbl.textContent = "Sources:"; sourcesEl.appendChild(lbl);
                        links.forEach(s => { const a = document.createElement("a"); a.href = s.url; a.target = "_blank"; a.rel = "noopener noreferrer"; a.className = "tm-source-link"; a.textContent = s.title; sourcesEl.appendChild(a); });
                    } else if (evt.source) { const lbl = document.createElement("span"); lbl.className = "tm-sources-label"; lbl.textContent = `Source: ${evt.source}`; sourcesEl.appendChild(lbl); }
                    resultsEl.style.display = "grid";
                    const pct = Math.round(((Number(evt.nowPrice) - Number(evt.pastPrice)) / Number(evt.pastPrice)) * 100);
                    conclusionEl.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><p>The <strong>${evt.pastItem ?? item}</strong> in ${evt.year ?? year} cost ${evt.pastPriceFormatted}. Today's equivalent costs ${evt.nowPriceFormatted} — a <strong>${pct}% jump</strong>. Your idle savings didn't come close.</p>`;
                } else if (evt.type === "error") { addLog("⚠ " + evt.message); }
            }
        }
    } catch (err: any) { addLog("Network error: " + (err?.message ?? "unknown")); }
    finally { btnText.textContent = "Look it up →"; lookupBtn.disabled = false; }
});
itemInput.addEventListener("keydown", e => { if (e.key === "Enter") lookupBtn.click(); });
yearInput.addEventListener("keydown", e => { if (e.key === "Enter") lookupBtn.click(); });

