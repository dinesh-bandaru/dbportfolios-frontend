/* ══════════════════════════════════════════════════
   SLIDE 3 — Interactive FD Waterfall
   ══════════════════════════════════════════════════ */
function updateWaterfall() {
    const wfFd  = Number((document.getElementById("wf-fd")  as HTMLInputElement).value);
    const wfTax = Number((document.getElementById("wf-tax") as HTMLInputElement).value);
    const wfInf = Number((document.getElementById("wf-inf") as HTMLInputElement).value);

    const set = (id: string, v: string) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    set("wf-fd-disp",  wfFd  + "%");
    set("wf-tax-disp", wfTax + "%");
    set("wf-inf-disp", wfInf + "%");

    const aftertax = wfFd * (1 - wfTax / 100);
    const real     = aftertax - wfInf;
    const taxDrain = wfFd - aftertax;

    const aftertaxW = Math.max(0, (aftertax / wfFd) * 100);
    const realW     = Math.max(0, (real / wfFd) * 100);

    const setW = (id: string, w: number) => { const el = document.getElementById(id) as HTMLElement; if (el) el.style.width = w + "%"; };
    setW("wfb-nominal",  100);
    setW("wfb-aftertax", aftertaxW);
    setW("wfb-lost-tax", 100 - aftertaxW);

    const realBar = document.getElementById("wfb-real") as HTMLElement;
    if (realBar) {
        realBar.style.width = Math.max(0, realW) + "%";
        realBar.style.background = real < 0 ? "#ef4444" : real < 1.5 ? "#f59e0b" : "#10b981";
    }
    setW("wfb-lost-inf", 100 - Math.max(0, realW));

    set("wfv-nominal",  wfFd.toFixed(1)  + "%");
    set("wfv-aftertax", aftertax.toFixed(1) + "%");
    set("wfv-real",     (real >= 0 ? "+" : "") + real.toFixed(1) + "%");
    set("wf-drain-tax", `↓ Tax (${wfTax}%) eats −${taxDrain.toFixed(1)}%`);
    set("wf-drain-inf", `↓ Inflation (${wfInf}%) burns −${wfInf.toFixed(1)}%`);

    const icon    = document.getElementById("wf-verdict-icon");
    const txt     = document.getElementById("wf-verdict-text");
    const hl      = document.getElementById("wf-real-hl");
    const verdict = document.getElementById("wf-verdict");
    const realStr = (real >= 0 ? "+" : "") + real.toFixed(1) + "%";
    if (hl) hl.textContent = realStr;
    if (real < 0) {
        if (icon) icon.textContent = "🔴";
        if (txt)  txt.innerHTML = `Your FD is <strong>destroying wealth in real terms</strong> — <strong style="color:#ef4444">${realStr}/yr</strong>. You are working to stand still.`;
        if (verdict) verdict.style.borderColor = "#ef4444";
    } else if (real < 1.5) {
        if (icon) icon.textContent = "⚠️";
        if (txt)  txt.innerHTML = `Real return of <strong>${realStr}</strong> — barely above zero. Inflation is winning.`;
        if (verdict) verdict.style.borderColor = "#f59e0b";
    } else {
        if (icon) icon.textContent = "🟡";
        if (txt)  txt.innerHTML = `A ${realStr} real return is <em>positive</em> — but equity typically delivers 2–4× more over the long run.`;
        if (verdict) verdict.style.borderColor = "#10b981";
    }
}
["wf-fd","wf-tax","wf-inf"].forEach(id => document.getElementById(id)?.addEventListener("input", updateWaterfall));

/* ══════════════════════════════════════════════════
   SLIDE 4 — Compounding
   ══════════════════════════════════════════════════ */
const compYears = document.getElementById("comp-years") as HTMLInputElement;
const compRate  = document.getElementById("comp-rate")  as HTMLInputElement;

function updateComp() {
    const y = Number(compYears.value);
    const r = Number(compRate.value) / 100;
    const yd = document.getElementById("comp-years-display");
    const rd = document.getElementById("comp-rate-display");
    if (yd) yd.textContent = y + " yrs";
    if (rd) rd.textContent = compRate.value + "%";
    const final = 100000 * Math.pow(1 + r, y);
    const res   = document.getElementById("comp-result");
    const gain  = document.getElementById("comp-gain");
    const lbl   = document.getElementById("comp-base-label");
    if (res)  res.textContent  = fmt(final);
    if (gain) gain.textContent = "+" + fmt(final - 100000);
    if (lbl)  lbl.textContent  = fmt(100000) + " grows to";
    renderHens();
}
function renderHens() {
    const y    = Number(compYears.value);
    const wrap = document.getElementById("comp-visual");
    if (!wrap) return;
    const hens = Math.min(Math.round(Math.pow(1.2, Math.min(y, 10))), 32);
    const disp = Math.min(hens, 16);
    wrap.innerHTML = "";
    const row = document.createElement("div"); row.className = "hens-row";
    for (let i = 0; i < disp; i++) {
        const h = document.createElement("span");
        h.className = "hen"; h.style.animationDelay = `${i * 0.06}s`;
        h.textContent = i < disp / 2 ? "🐔" : "🥚";
        row.appendChild(h);
    }
    if (hens > 16) { const m = document.createElement("span"); m.className = "hen-more"; m.textContent = `+${hens - 16} more…`; row.appendChild(m); }
    wrap.appendChild(row);
}
compYears?.addEventListener("input", updateComp);
compRate?.addEventListener("input",  updateComp);

/* ── Init ──────────────────────────────────────────────────────────── */
goTo(0);
updateWaterfall();
</script>

