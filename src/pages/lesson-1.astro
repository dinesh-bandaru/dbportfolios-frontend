const LF_SALARY_GROWTH = 0.07;
const LF_YEARS = 20;
const SALARY_DEFAULTS: Record<string,number> = { "₹":1200000, "$":65000, "€":40000, "£":35000, "A$":80000 };

let lfCurrency    = bestCurrencyOption(GEO.symbol);
let lfBaseSalary  = SALARY_DEFAULTS[lfCurrency] ?? 65000;
let lfCurrentYear = 0;
const lfRenderedIds = new Set<string>();

function lfFmt(n: number, sym: string): string {
    const a = Math.abs(n);
    if (sym === "₹") {
        const r = Math.round(a);
        if (r >= 10000000) return sym + (a/10000000).toFixed(1) + "Cr";
        if (r >= 100000)   return sym + (a/100000).toFixed(1) + "L";
        if (r >= 1000)     return sym + (a/1000).toFixed(0) + "K";
        return sym + r.toLocaleString("en-IN");
    }
    if (a >= 1000000) return sym + (a/1000000).toFixed(1) + "M";
    if (a >= 10000)   return sym + (a/1000).toFixed(0) + "K";
    if (a >= 1000)    return sym + (a/1000).toFixed(1) + "K";
    return sym + Math.round(a);
}
function lfBasePrice(item: LfItem): number { return item.prices[lfCurrency] ?? item.prices["$"] ?? 0; }
function lfAffordability(price: number, monthly: number): "green"|"amber"|"red" {
    const r = price / monthly;
    if (r < 0.15) return "green";
    if (r < 0.40) return "amber";
    return "red";
}
function lfStageFor(yr: number): LifeStage {
    let s = LF_STAGES[0];
    for (const ls of LF_STAGES) { if (yr >= ls.from) s = ls; }
    return s;
}
function lfUpdateStageBanner(yr: number) {
    const stage = lfStageFor(yr);
    const icon  = document.getElementById("lf-stage-icon");
    const name  = document.getElementById("lf-stage-name");
    const desc  = document.getElementById("lf-stage-desc");
    const banner= document.getElementById("lf-stage-banner");
    if (icon)   icon.textContent  = stage.icon;
    if (name)   name.textContent  = stage.name;
    if (desc)   desc.textContent  = stage.desc;
    if (banner) banner.style.borderColor = stage.color;
}
function lfSyncScrubber() {
    const s = document.getElementById("lf-scrubber") as HTMLInputElement;
    if (!s) return;
    const yr  = Number(s.value);
    const pct = (yr / LF_YEARS) * 100;
    s.style.background = `linear-gradient(to right, var(--accent-green) ${pct}%, rgba(255,255,255,0.1) ${pct}%)`;
    const badge = document.getElementById("lf-year-badge");
    if (badge) badge.textContent = yr === 0 ? "Today" : `Year ${yr}`;
    lfRenderYear(yr);
}
function lfAddRow(item: LfItem, monthly: number) {
    const tbody = document.getElementById("lf-tbody");
    if (!tbody || lfRenderedIds.has(item.id)) return;
    lfRenderedIds.add(item.id);
    const price0 = lfBasePrice(item);
    const color0 = lfAffordability(price0, monthly);
    const pct0   = Math.round((price0 / monthly) * 100);
    const tr     = document.createElement("tr");
    tr.id        = `lf-row-${item.id}`;
    tr.className = "lf-row lf-row-new";
    tr.innerHTML =
        `<td class="lf-td lf-td-item">${item.emoji} ${item.label}</td>` +
        `<td class="lf-td lf-td-price" id="lf-price-${item.id}">${lfFmt(price0, lfCurrency)}</td>` +
        `<td class="lf-td lf-td-pct"   id="lf-pct-${item.id}">${pct0}%</td>` +
        `<td class="lf-td lf-td-dot"><span class="lf-status lf-status--${color0}" id="lf-dot-${item.id}"></span></td>`;
    tbody.appendChild(tr);
    requestAnimationFrame(() => { tr.classList.remove("lf-row-new"); });
}
function lfDropRow(item: LfItem) {
    const tr = document.getElementById(`lf-row-${item.id}`);
    if (!tr || tr.classList.contains("lf-row-dropped")) return;
    tr.classList.add("lf-row-dropped");
    if (item.dropNote) {
        const cell = tr.querySelector(".lf-td-item") as HTMLElement | null;
        if (cell && !cell.querySelector(".lf-drop-note")) {
            const note = document.createElement("span");
            note.className = "lf-drop-note";
            note.textContent = ` — ${item.dropNote}`;
            cell.appendChild(note);
        }
    }
}
function lfRestoreRow(item: LfItem) {
    const tr = document.getElementById(`lf-row-${item.id}`);
    if (!tr) return;
    tr.classList.remove("lf-row-dropped");
    tr.querySelector(".lf-drop-note")?.remove();
}
function lfRemoveRow(item: LfItem) {
    document.getElementById(`lf-row-${item.id}`)?.remove();
    lfRenderedIds.delete(item.id);
}
function lfRenderYear(yr: number) {
    lfCurrentYear = yr;
    const salary  = lfBaseSalary * Math.pow(1 + LF_SALARY_GROWTH, yr);
    const monthly = salary / 12;
    const sd = document.getElementById("lf-salary-disp");
    const md = document.getElementById("lf-monthly-disp");
    if (sd) sd.textContent = lfFmt(salary, lfCurrency) + " / yr";
    if (md) md.textContent = lfFmt(monthly, lfCurrency) + " / mo";
    lfUpdateStageBanner(yr);
    for (const item of LF_ITEMS) {
        if (yr >= item.appearsAt) lfAddRow(item, monthly); else lfRemoveRow(item);
        if (item.dropsAt !== undefined) { if (yr >= item.dropsAt) lfDropRow(item); else lfRestoreRow(item); }
    }
    let redCount = 0;
    const active = LF_ITEMS.filter(i => yr >= i.appearsAt);
    for (const item of active) {
        const isDropped = item.dropsAt !== undefined && yr >= item.dropsAt;
        const price     = lfBasePrice(item) * Math.pow(1 + item.inflRate, yr);
        const color     = isDropped ? "dropped" : lfAffordability(price, monthly);
        const pct       = Math.round((price / monthly) * 100);
        const priceEl   = document.getElementById(`lf-price-${item.id}`);
        const pctEl     = document.getElementById(`lf-pct-${item.id}`);
        const dotEl     = document.getElementById(`lf-dot-${item.id}`);
        if (priceEl) priceEl.textContent = lfFmt(price, lfCurrency);
        if (pctEl)   pctEl.textContent   = isDropped ? "—" : pct + "%";
        if (dotEl)   dotEl.className     = `lf-status lf-status--${color}`;
        if (!isDropped && color === "red") redCount++;
    }
    const rc = document.getElementById("lf-red-count");
    if (rc) { rc.textContent = String(redCount); rc.className = "lf-stat-val " + (redCount >= 4 ? "lf-stat-red" : redCount >= 2 ? "lf-stat-amber" : "lf-green"); }

    const amberCount = active.filter(i => { if (i.dropsAt !== undefined && yr >= i.dropsAt) return false; const p = lfBasePrice(i) * Math.pow(1 + i.inflRate, yr); return lfAffordability(p, monthly) === "amber"; }).length;
    const redItems   = active.filter(i => { if (i.dropsAt !== undefined && yr >= i.dropsAt) return false; const p = lfBasePrice(i) * Math.pow(1 + i.inflRate, yr); return lfAffordability(p, monthly) === "red"; });
    const callout    = document.getElementById("lf-callout") as HTMLElement | null;
    const calloutTxt = document.getElementById("lf-callout-text");
    if (callout && calloutTxt) {
        if (yr >= 14 && redCount >= 3) {
            calloutTxt.innerHTML = `You stopped renting and bought a home — but the EMI is bigger than rent ever was. School fees, parents' medical, and the loan landed together. You're earning ${Math.round(LF_SALARY_GROWTH * 100)}% more every year, but <strong>${redCount} expenses are now genuinely out of reach</strong>.`;
            callout.className = "callout callout-red"; callout.style.display = "flex";
        } else if (yr >= 14) {
            calloutTxt.innerHTML = `You've bought a home — rent is gone, but the <strong>home loan EMI is larger</strong>. School fees and parents' care arrive at the same time. The obligations don't stop stacking.`;
            callout.className = "callout callout-amber"; callout.style.display = "flex";
        } else if (yr >= 10 && redCount >= 1) {
            calloutTxt.innerHTML = `A child changed the numbers completely. The gym and solo trips are gone — childcare, health insurance, and family savings took their place. Even with your raises, <strong>something has slipped into the red.</strong>`;
            callout.className = "callout callout-red"; callout.style.display = "flex";
        } else if (yr >= 10) {
            calloutTxt.innerHTML = `A baby means expenses you never budgeted for. Childcare alone can match your rent. <strong>Keep scrubbing to see what's coming.</strong>`;
            callout.className = "callout callout-amber"; callout.style.display = "flex";
        } else if (yr >= 7 && amberCount >= 2) {
            calloutTxt.innerHTML = `Rent, groceries, utilities, a car — none of this was in your single-life budget. <strong>${amberCount} expenses now take a noticeable chunk of salary.</strong> You're not struggling yet. But saving is harder than it should be.`;
            callout.className = "callout callout-amber"; callout.style.display = "flex";
        } else if (yr >= 4 && amberCount >= 1) {
            calloutTxt.innerHTML = `Date nights, saving for a trip — <strong>spending grows naturally with life.</strong> Nothing alarming yet. Keep going.`;
            callout.className = "callout callout-amber"; callout.style.display = "flex";
        } else { callout.style.display = "none"; }
    }
}
function lfBuildGrid() {
    const tbody = document.getElementById("lf-tbody");
    if (!tbody) return;
    tbody.innerHTML = "";
    lfRenderedIds.clear();
    lfSyncScrubber();
}
document.getElementById("lf-scrubber")?.addEventListener("input", lfSyncScrubber);
document.getElementById("lf-apply-btn")?.addEventListener("click", () => {
    const salInput  = document.getElementById("lf-salary") as HTMLInputElement;
    const activeOpt = document.querySelector(".lf-curr-opt--active") as HTMLElement | null;
