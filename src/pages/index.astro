---
import Layout from "../layouts/Layout.astro";
import MarketTicker from "../components/MarketTicker.astro";
import BrandLogo from "../components/BrandLogo.astro";
---

<Layout title="DB Portfolios | Master Your Assets">
    <MarketTicker />
    <main class="landing-container">
        <div class="background-elements" aria-hidden="true">
            <div class="glow glow-1"></div>
            <div class="glow glow-2"></div>
            <div class="glow glow-3"></div>
            <div class="dot dot-1"></div>
            <div class="dot dot-2"></div>
            <div class="dot dot-3"></div>
            <div class="dot dot-4"></div>
            <div class="dot dot-5"></div>
            <div class="dot dot-6"></div>
            <div class="dot dot-7"></div>
            <div class="dot dot-8"></div>
            <div class="dot dot-9"></div>
            <div class="dot dot-10"></div>
            <div class="dot dot-11"></div>
            <div class="dot dot-12"></div>
            <svg
                class="chart-line"
                viewBox="0 0 1000 400"
                preserveAspectRatio="none"
            >
                <path
                    d="M0,300 Q150,250 300,280 T600,150 T1000,50"
                    fill="none"
                    stroke="rgba(16, 185, 129, 0.15)"
                    stroke-width="2"></path>
            </svg>
        </div>

        <nav class="navbar">
            <div class="nav-content">
                <div class="logo">
                    <BrandLogo width="160" height="28" />
                </div>
                <div class="nav-actions">
                    <a href="/login?mode=login" class="nav-link">Log In</a>
                    <a href="/login?mode=signup" class="nav-signup">Sign Up</a>
                </div>
            </div>
        </nav>

        <section class="hero">
            <div class="hero-content">
                <div class="badge">v1.0 Now Live</div>
                <h1>
                    Master Your <span class="text-gradient"
                        >Financial Future</span
                    >
                </h1>
                <p>
                    Secure, data-driven portfolio management for the modern
                    investor. Track, analyze, and optimize your assets in one
                    place.
                </p>
                <div class="hero-actions">
                    <a href="/login" class="btn-primary">Get Started Free</a>
                    <a href="#features" class="btn-secondary">Learn More</a>
                </div>
            </div>
        </section>

        <section id="features" class="features">
            <div class="feature-grid">
                <div class="feature-card">
                    <div class="feature-icon">📊</div>
                    <h3>Real-time Tracking</h3>
                    <p>Live data feeds for global markets and crypto assets.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🛡️</div>
                    <h3>Bank-Grade Security</h3>
                    <p>Stateless authentication and encrypted data storage.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🚀</div>
                    <h3>Advanced Analytics</h3>
                    <p>
                        Deep insights into your portfolio performance and risk.
                    </p>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .landing-container {
        min-height: 100vh;
        color: var(--text-primary);
        position: relative;
        overflow-x: hidden;
    }

    /* Background */
    .background-elements {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
    }

    .glow {
        position: absolute;
        width: 50vw;
        height: 50vw;
        border-radius: 50%;
        filter: blur(120px);
        z-index: 0;
        opacity: 0.1;
        animation: float 25s infinite alternate ease-in-out;
    }

    .glow-1 {
        background: var(--accent-green);
        top: -10%;
        right: -10%;
    }
    .glow-2 {
        background: var(--accent-blue);
        bottom: -10%;
        left: -10%;
        animation-delay: -5s;
    }
    .glow-3 {
        background: #8b5cf6;
        top: 30%;
        left: 10%;
        width: 30vw;
        height: 30vw;
        animation-delay: -10s;
    }

    @keyframes float {
        from {
            transform: translate(0, 0) scale(1);
        }
        to {
            transform: translate(5%, 5%) scale(1.1);
        }
    }

    .chart-line {
        position: absolute;
        bottom: 10%;
        left: 0;
        width: 100%;
        height: 30%;
        opacity: 0.2;
    }

    /* Floating Dots */
    .dot {
        position: absolute;
        border-radius: 50%;
        background: var(--accent-green);
        pointer-events: none;
        animation: drift linear infinite;
    }

    .dot-1 {
        width: 4px;
        height: 4px;
        top: 12%;
        left: 8%;
        opacity: 0.5;
        animation-duration: 18s;
    }
    .dot-2 {
        width: 6px;
        height: 6px;
        top: 25%;
        left: 85%;
        opacity: 0.35;
        animation-duration: 22s;
        animation-delay: -3s;
    }
    .dot-3 {
        width: 3px;
        height: 3px;
        top: 55%;
        left: 15%;
        opacity: 0.6;
        animation-duration: 15s;
        animation-delay: -7s;
    }
    .dot-4 {
        width: 5px;
        height: 5px;
        top: 70%;
        left: 72%;
        opacity: 0.3;
        animation-duration: 25s;
        animation-delay: -2s;
    }
    .dot-5 {
        width: 3px;
        height: 3px;
        top: 40%;
        left: 50%;
        opacity: 0.45;
        animation-duration: 20s;
        animation-delay: -10s;
    }
    .dot-6 {
        width: 7px;
        height: 7px;
        top: 85%;
        left: 30%;
        opacity: 0.25;
        animation-duration: 28s;
        animation-delay: -5s;
    }
    .dot-7 {
        width: 4px;
        height: 4px;
        top: 18%;
        left: 60%;
        opacity: 0.4;
        animation-duration: 16s;
        animation-delay: -8s;
    }
    .dot-8 {
        width: 5px;
        height: 5px;
        top: 65%;
        left: 42%;
        opacity: 0.35;
        animation-duration: 23s;
        animation-delay: -12s;
    }
    .dot-9 {
        width: 3px;
        height: 3px;
        top: 35%;
        left: 92%;
        opacity: 0.55;
        animation-duration: 19s;
        animation-delay: -1s;
    }
    .dot-10 {
        width: 6px;
        height: 6px;
        top: 80%;
        left: 88%;
        opacity: 0.2;
        animation-duration: 26s;
        animation-delay: -6s;
    }
    .dot-11 {
        width: 4px;
        height: 4px;
        top: 48%;
        left: 25%;
        opacity: 0.4;
        animation-duration: 21s;
        animation-delay: -9s;
    }
    .dot-12 {
        width: 3px;
        height: 3px;
        top: 10%;
        left: 38%;
        opacity: 0.5;
        animation-duration: 17s;
        animation-delay: -4s;
    }

    @keyframes drift {
        0% {
            transform: translate(0, 0);
        }
        25% {
            transform: translate(30px, -40px);
        }
        50% {
            transform: translate(-20px, -80px);
        }
        75% {
            transform: translate(40px, -30px);
        }
        100% {
            transform: translate(0, 0);
        }
    }

    /* Nav */
    .navbar {
        padding: 0.4rem 0;
        position: relative;
        z-index: 10;
        border-bottom: 1px solid var(--border-color);
        background: rgba(10, 10, 11, 0.5);
        backdrop-filter: blur(10px);
    }

    .nav-content {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 1.5rem;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 800;
        font-size: 1.25rem;
        letter-spacing: -0.02em;
    }

    .logo svg {
        width: 24px;
        height: 24px;
        color: var(--accent-green);
    }

    .nav-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .nav-link {
        color: var(--text-primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9375rem;
        padding: 0.625rem 1rem;
        border-radius: 12px;
        transition: background 0.2s;
        opacity: 0.8;
    }

    .nav-link:hover {
        opacity: 1;
        background: rgba(255, 255, 255, 0.05);
    }

    .nav-signup {
        background: var(--accent-green);
        color: #000;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9375rem;
        padding: 0.625rem 1.25rem;
        border-radius: 12px;
        transition: transform 0.2s;
    }

    .nav-signup:hover {
        transform: translateY(-1px);
    }

    /* Hero */
    .hero {
        padding: 8rem 1.5rem 4rem;
        text-align: center;
        position: relative;
        z-index: 10;
    }

    .badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        background: rgba(16, 185, 129, 0.1);
        color: var(--accent-green);
        border-radius: 99px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 2rem;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

    h1 {
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        font-weight: 900;
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.5rem;
        max-width: 900px;
        margin-inline: auto;
    }

    .text-gradient {
        background: linear-gradient(
            135deg,
            var(--accent-green) 0%,
            #34d399 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero p {
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: var(--text-secondary);
        max-width: 600px;
        margin: 0 auto 3rem;
        line-height: 1.6;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    .btn-primary {
        background: var(--accent-green);
        color: #000;
        padding: 0.875rem 2rem;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        transition: transform 0.2s;
    }

    .btn-secondary {
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        padding: 0.875rem 2rem;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 600;
        transition: background 0.2s;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
    }
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.05);
    }

    /* Features */
    .features {
        padding: 6rem 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 10;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }

    .feature-card {
        padding: 2.5rem;
        background: rgba(23, 23, 26, 0.5);
        border: 1px solid var(--border-color);
        border-radius: 24px;
        backdrop-filter: blur(10px);
        transition: border-color 0.2s;
    }

    .feature-card:hover {
        border-color: var(--accent-green);
    }

    .feature-icon {
        font-size: 2.5rem;
        margin-bottom: 1.5rem;
    }

    .feature-card h3 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }

    .feature-card p {
        color: var(--text-secondary);
        line-height: 1.6;
    }

    @media (max-width: 640px) {
        .hero-actions {
            flex-direction: column;
        }
        .btn-primary,
        .btn-secondary {
            width: 100%;
        }
    }
</style>
