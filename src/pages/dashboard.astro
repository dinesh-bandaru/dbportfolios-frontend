---
import Layout from "../layouts/Layout.astro";
import MarketTicker from "../components/MarketTicker.astro";
import BrandLogo from "../components/BrandLogo.astro";

const API_BASE_URL = import.meta.env.DEV
    ? "http://localhost:8787"
    : "https://dbportfolios-backend.blr-bull.workers.dev";
---

<Layout title="Course | DB Portfolios">
    <div id="auth-checker" style="display: none;">
        <MarketTicker />

        <nav class="dashboard-nav">
            <div class="nav-container">
                <div class="logo">
                    <a
                        href="/dashboard"
                        style="display:flex;align-items:center;color:#fff;text-decoration:none;"
                    >
                        <BrandLogo width="150" height="26" />
                    </a>
                </div>
                <div class="nav-links">
                    <a href="/dashboard" class="active">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><polygon points="5 3 19 12 5 21 5 3"
                            ></polygon></svg
                        >
                        Course
                    </a>
                </div>
                <div class="user-menu">
                    <span id="user-name">Loading...</span>
                    <button id="logout-btn" class="logout-btn">Log Out</button>
                </div>
            </div>
        </nav>

        <main class="course-layout" data-api-url={API_BASE_URL}>
            <!-- Left: Course Outline Sidebar -->
            <aside class="course-sidebar left-sidebar" id="left-sidebar">
                <div class="sidebar-card glass-card">
                    <div class="sidebar-header">
                        <h2>Course Outline</h2>
                        <span class="progress-badge" id="progress-badge">—</span
                        >
                    </div>
                    <div class="lesson-list" id="lesson-list">
                        <div class="sidebar-loading">
                            <div class="loading-spinner small"></div>
                        </div>
                    </div>
                    <div class="sidebar-footer">
                        <div class="course-progress-bar">
                            <div
                                class="progress-fill"
                                id="progress-fill"
                                style="width: 0%"
                            >
                            </div>
                        </div>
                        <p class="progress-text">
                            Start watching to track progress
                        </p>
                    </div>
                </div>

                <div class="info-card glass-card">
                    <div class="info-row">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent-green)"
                            stroke-width="2"
                            ><circle cx="12" cy="12" r="10"></circle><polyline
                                points="12 6 12 12 16 14"></polyline></svg
                        >
                        <span id="info-total-duration">—</span>
                    </div>
                    <div class="info-row">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent-green)"
                            stroke-width="2"
                            ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"
                            ></path><path
                                d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
                            ></path></svg
                        >
                        <span id="info-lesson-count">—</span>
                    </div>
                    <div class="info-row">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent-green)"
                            stroke-width="2"
                            ><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"
                            ></path><polyline points="22 4 12 14.01 9 11.01"
                            ></polyline></svg
                        >
                        <span>Certificate on completion</span>
                    </div>
                </div>
            </aside>

            <!-- Middle: Main content area (Video) -->
            <div class="course-main" id="course-main">
                <div class="main-top-bar">
                    <button
                        id="toggle-sidebar"
                        class="toggle-btn highlight-hover"
                        title="Toggle Outline"
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><line x1="3" y1="12" x2="21" y2="12"></line><line
                                x1="3"
                                y1="6"
                                x2="21"
                                y2="6"></line><line
                                x1="3"
                                y1="18"
                                x2="21"
                                y2="18"></line></svg
                        >
                    </button>
                    <div class="lesson-badge">
                        <span class="lesson-number">Lesson 1</span>
                        <span class="lesson-divider">·</span>
                        <span class="lesson-duration" id="lesson-duration"
                            >—</span
                        >
                    </div>
                </div>

                <div class="video-container glass-card" id="video-container">
                    <div class="video-loading" id="video-loading">
                        <div class="loading-spinner"></div>
                        <p>Loading course video...</p>
                    </div>
                    <div
                        class="video-error"
                        id="video-error"
                        style="display:none;"
                    >
                        <svg
                            width="48"
                            height="48"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent-red)"
                            stroke-width="1.5"
                            ><circle cx="12" cy="12" r="10"></circle><line
                                x1="12"
                                y1="8"
                                x2="12"
                                y2="12"></line><line
                                x1="12"
                                y1="16"
                                x2="12.01"
                                y2="16"></line></svg
                        >
                        <p id="video-error-text">Unable to load video.</p>
                        <button class="retry-btn" id="retry-btn">Retry</button>
                    </div>
                </div>

                <div class="lesson-info">
                    <div class="lesson-header">
                        <h1 id="lesson-title">Loading...</h1>
                        <p id="lesson-description" class="lesson-desc">
                            Loading course details...
                        </p>
                    </div>
                </div>
            </div>

            <!-- Right: AI Chat -->
            <aside class="course-sidebar right-sidebar" id="right-sidebar">
                <div class="chat-container glass-card">
                    <div class="chat-header">
                        <div class="chat-title">
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--accent-green)"
                                stroke-width="2"
                                ><path
                                    d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
                                ></path></svg
                            >
                            <h3>AI Assistant</h3>
                        </div>
                        <p>Ask questions about this lesson</p>
                    </div>
                    <div class="chat-messages" id="chat-messages">
                        <div class="chat-message assistant">
                            <div class="chat-message-header">
                                <svg
                                    width="14"
                                    height="14"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
                                    ></path></svg
                                > AI Assistant
                            </div>
                            <div class="chat-bubble">
                                <p style="margin:0">
                                    Hi! I'm your AI assistant. Ask me anything
                                    about the current video.
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="chat-input-area">
                        <input
                            type="text"
                            id="chat-input"
                            placeholder="Type your question..."
                            autocomplete="off"
                        />
                        <button
                            id="chat-send"
                            class="send-btn"
                            title="Send message"
                        >
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><line x1="22" y1="2" x2="11" y2="13"
                                ></line><polygon
                                    points="22 2 15 22 11 13 2 9 22 2"
                                ></polygon></svg
                            >
                        </button>
                    </div>
                </div>
            </aside>
        </main>
    </div>

    <script>
        // ─── Auth check ───
        function decodeJwtPayload(token: string) {
            try {
                const base64 = token
                    .split(".")[1]
                    .replace(/-/g, "+")
                    .replace(/_/g, "/");
                return JSON.parse(atob(base64));
            } catch {
                return null;
            }
        }

        const token = localStorage.getItem("auth_token");
        if (!token) {
            window.location.href = "/login";
        } else {
            const authChecker = document.getElementById("auth-checker");
            if (authChecker) authChecker.style.display = "block";

            const userName = document.getElementById("user-name");
            if (userName) {
                const payload = decodeJwtPayload(token);
                if (payload?.name)
                    userName.textContent = `Welcome, ${payload.name}!`;
                else if (payload?.email)
                    userName.textContent = `Welcome, ${payload.email}!`;
                else userName.textContent = "Welcome back!";
            }
        }

        // ─── Logout ───
        document.getElementById("logout-btn")?.addEventListener("click", () => {
            localStorage.removeItem("auth_token");
            window.location.href = "/login";
        });

        // ─── Fetch course data ───
        const courseLayout = document.querySelector(
            ".course-layout",
        ) as HTMLElement;
        const apiBaseUrl = courseLayout?.dataset.apiUrl || "";
        let currentLessonId: string | null = null;

        // ─── Load sidebar lesson list ───
        async function loadLessonList() {
            try {
                const res = await fetch(
                    `${apiBaseUrl}/api/protected/course/lessons`,
                    {
                        headers: { Authorization: `Bearer ${token}` },
                    },
                );
                if (!res.ok) throw new Error("Failed to load lessons");

                const data = (await res.json()) as {
                    lessons: Array<{
                        id: string;
                        title: string;
                        description: string | null;
                        sortOrder: number;
                        duration: string | null;
                    }>;
                    totalDuration: string;
                    lessonCount: number;
                };

                // Update course info card
                const infoTotalDuration = document.getElementById(
                    "info-total-duration",
                );
                const infoLessonCount =
                    document.getElementById("info-lesson-count");
                const progressBadge = document.getElementById("progress-badge");

                if (infoTotalDuration)
                    infoTotalDuration.textContent = data.totalDuration
                        ? `${data.totalDuration} total`
                        : "—";
                if (infoLessonCount)
                    infoLessonCount.textContent = `${data.lessonCount} Lesson${data.lessonCount !== 1 ? "s" : ""}`;
                if (progressBadge)
                    progressBadge.textContent = `0 / ${data.lessonCount}`;

                // Render sidebar lesson items
                const lessonList = document.getElementById("lesson-list");
                if (!lessonList) return;
                lessonList.innerHTML = "";

                data.lessons.forEach((lesson, index) => {
                    const item = document.createElement("div");
                    item.className = "lesson-item";
                    item.dataset.lessonId = lesson.id;
                    item.innerHTML = `
                        <div class="lesson-item-status">
                            <div class="status-ring">
                                <svg width="14" height="14" viewBox="0 0 24 24"
                                    fill="currentColor" stroke="none">
                                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                                </svg>
                            </div>
                        </div>
                        <div class="lesson-item-info">
                            <span class="lesson-item-label">Lesson ${index + 1}</span>
                            <span class="lesson-item-title">${lesson.title}</span>
                        </div>
                        <span class="lesson-item-duration">${lesson.duration || "—"}</span>
                    `;
                    item.addEventListener("click", () =>
                        selectLesson(lesson.id),
                    );
                    lessonList.appendChild(item);
                });

                // Auto-select first lesson
                if (data.lessons.length > 0) {
                    selectLesson(data.lessons[0].id);
                }
            } catch (err) {
                console.error("Error loading lessons:", err);
            }
        }

        // ─── Select and play a lesson ───
        async function selectLesson(lessonId: string) {
            if (currentLessonId === lessonId) return;
            currentLessonId = lessonId;

            // Reset Chat UI for new lesson
            const chatMessages = document.getElementById("chat-messages");
            if (chatMessages) {
                chatMessages.innerHTML = "";
                const history = window.chatHistories?.[lessonId] || [];
                if (history.length === 0) {
                    const temp = currentLessonId;
                    currentLessonId = null; // Prevent pushing to history
                    addChatMessage(
                        "assistant",
                        "Hi! I'm your AI assistant. Ask me anything about this lesson.",
                    );
                    currentLessonId = temp;
                } else {
                    const temp = currentLessonId;
                    currentLessonId = null;
                    history.forEach((msg: any) =>
                        addChatMessage(msg.role, msg.content),
                    );
                    currentLessonId = temp;
                }
            }

            // Update sidebar active state
            document.querySelectorAll(".lesson-item").forEach((el) => {
                const item = el as HTMLElement;
                if (item.dataset.lessonId === lessonId) {
                    item.classList.add("active");
                    const ring = item.querySelector(".status-ring");
                    if (ring) ring.classList.add("playing");
                } else {
                    item.classList.remove("active");
                    const ring = item.querySelector(".status-ring");
                    if (ring) ring.classList.remove("playing");
                }
            });

            // Load the video
            await loadLesson(lessonId);
        }

        // ─── Load a specific lesson video ───
        async function loadLesson(lessonId: string) {
            const loadingEl = document.getElementById("video-loading");
            const errorEl = document.getElementById("video-error");
            const errorText = document.getElementById("video-error-text");
            const videoContainer = document.getElementById("video-container");

            // Remove old iframe
            const oldIframe = videoContainer?.querySelector("iframe");
            if (oldIframe) oldIframe.remove();

            if (loadingEl) loadingEl.style.display = "flex";
            if (errorEl) errorEl.style.display = "none";

            try {
                const res = await fetch(
                    `${apiBaseUrl}/api/protected/course?lessonId=${encodeURIComponent(lessonId)}`,
                    { headers: { Authorization: `Bearer ${token}` } },
                );

                if (!res.ok) {
                    throw new Error(
                        res.status === 401
                            ? "Session expired. Please log in again."
                            : "Failed to load lesson.",
                    );
                }

                const data = (await res.json()) as {
                    signedToken: string;
                    customerCode: string;
                    lesson: {
                        id: string;
                        title: string;
                        description: string | null;
                        duration: string;
                        sortOrder: number;
                    };
                };

                // Hide loading
                if (loadingEl) loadingEl.style.display = "none";

                // Inject video iframe
                const iframe = document.createElement("iframe");
                iframe.src = `https://customer-${data.customerCode}.cloudflarestream.com/${data.signedToken}/iframe`;
                iframe.style.position = "absolute";
                iframe.style.inset = "0";
                iframe.style.width = "100%";
                iframe.style.height = "100%";
                iframe.style.border = "none";
                iframe.style.borderRadius = "16px";
                iframe.setAttribute(
                    "allow",
                    "accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture",
                );
                iframe.setAttribute("allowfullscreen", "true");
                videoContainer?.appendChild(iframe);

                // Update lesson info below video
                const lessonNumber = document.querySelector(".lesson-number");
                const lessonTitle = document.getElementById("lesson-title");
                const lessonDesc =
                    document.getElementById("lesson-description");
                const lessonDuration =
                    document.getElementById("lesson-duration");

                if (lessonNumber)
                    lessonNumber.textContent = `Lesson ${data.lesson.sortOrder}`;
                if (lessonTitle) lessonTitle.textContent = data.lesson.title;
                if (lessonDesc)
                    lessonDesc.textContent = data.lesson.description || "";
                if (lessonDuration)
                    lessonDuration.textContent = data.lesson.duration;
            } catch (err: any) {
                if (loadingEl) loadingEl.style.display = "none";
                if (errorEl) errorEl.style.display = "flex";
                if (errorText)
                    errorText.textContent =
                        err.message || "Unable to load video.";

                if (err.message?.includes("Session expired")) {
                    setTimeout(() => {
                        window.location.href = "/login";
                    }, 2000);
                }
            }
        }

        // ─── Sidebar & Tabs ───
        const toggleSidebarBtn = document.getElementById("toggle-sidebar");
        const courseLayoutCont = document.querySelector(".course-layout");

        toggleSidebarBtn?.addEventListener("click", () => {
            courseLayoutCont?.classList.toggle("sidebar-collapsed");
        });

        // ─── AI Chat ───
        const chatInput = document.getElementById(
            "chat-input",
        ) as HTMLInputElement;
        const chatSend = document.getElementById(
            "chat-send",
        ) as HTMLButtonElement;

        declare global {
            interface Window {
                chatHistories: Record<
                    string,
                    { role: "user" | "assistant"; content: string }[]
                >;
            }
        }
        window.chatHistories = window.chatHistories || {};

        function addChatMessage(role: "user" | "assistant", content: string) {
            const chatMessages = document.getElementById("chat-messages");
            if (!chatMessages) return null;

            const msgDiv = document.createElement("div");
            msgDiv.className = `chat-message ${role}`;

            const header = document.createElement("div");
            header.className = "chat-message-header";

            if (role === "assistant") {
                header.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg> AI Assistant`;
            } else {
                header.innerHTML = `You <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>`;
            }

            const bubbleDiv = document.createElement("div");
            bubbleDiv.className = "chat-bubble";
            bubbleDiv.innerHTML = `<p style="margin:0">${content}</p>`;

            msgDiv.appendChild(header);
            msgDiv.appendChild(bubbleDiv);

            chatMessages.appendChild(msgDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;

            if (currentLessonId && role !== "assistant") {
                if (!window.chatHistories[currentLessonId])
                    window.chatHistories[currentLessonId] = [];
                window.chatHistories[currentLessonId].push({ role, content });
            }

            return bubbleDiv;
        }

        async function sendChatMessage() {
            const text = chatInput.value.trim();
            if (!text || !currentLessonId) return;

            addChatMessage("user", text);
            chatInput.value = "";
            chatSend.disabled = true;

            const history =
                window.chatHistories[currentLessonId]?.slice(0, -1) || [];

            try {
                const res = await fetch(
                    `${apiBaseUrl}/api/protected/course/chat`,
                    {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            Authorization: `Bearer ${token}`,
                        },
                        body: JSON.stringify({
                            lessonId: currentLessonId,
                            message: text,
                            history: history,
                        }),
                    },
                );

                if (!res.ok) throw new Error("Chat request failed");

                const assistantBubble = addChatMessage("assistant", "");
                if (!assistantBubble) return;
                const contentP = assistantBubble.querySelector("p");

                const reader = res.body?.getReader();
                const decoder = new TextDecoder();
                let fullText = "";

                if (reader && contentP) {
                    let buffer = "";
                    while (true) {
                        const { done, value } = await reader.read();
                        if (done) break;
                        buffer += decoder.decode(value, { stream: true });
                        const lines = buffer.split("\n");
                        buffer = lines.pop() || ""; // keep incomplete line
                        for (const line of lines) {
                            if (line.startsWith("data: ")) {
                                const dataStr = line.slice(6);
                                if (dataStr.trim() === "[DONE]") continue;
                                try {
                                    const parsed = JSON.parse(dataStr);
                                    let contentChunk = "";

                                    if (parsed.response) {
                                        contentChunk = parsed.response;
                                    } else if (
                                        parsed.choices &&
                                        parsed.choices.length > 0
                                    ) {
                                        const delta = parsed.choices[0].delta;
                                        if (delta && delta.content) {
                                            contentChunk = delta.content;
                                        }
                                    }

                                    if (contentChunk) {
                                        fullText += contentChunk;
                                        contentP.innerHTML = fullText.replace(
                                            /\n/g,
                                            "<br/>",
                                        );
                                        const chatMsgs =
                                            document.getElementById(
                                                "chat-messages",
                                            );
                                        if (chatMsgs)
                                            chatMsgs.scrollTop =
                                                chatMsgs.scrollHeight;
                                    }
                                } catch (e) {
                                    console.error(
                                        "Parse error on chunk:",
                                        dataStr,
                                    );
                                }
                            }
                        }
                    }
                }

                if (currentLessonId) {
                    if (!window.chatHistories[currentLessonId])
                        window.chatHistories[currentLessonId] = [];
                    window.chatHistories[currentLessonId].push({
                        role: "assistant",
                        content: fullText,
                    });
                }
            } catch (err) {
                console.error("Chat error:", err);
                addChatMessage(
                    "assistant",
                    "Sorry, I encountered an error answering that. Please try again.",
                );
            } finally {
                chatSend.disabled = false;
                chatInput.focus();
            }
        }

        chatSend?.addEventListener("click", sendChatMessage);
        chatInput?.addEventListener("keypress", (e) => {
            if (e.key === "Enter") sendChatMessage();
        });

        // ─── Initialize ───
        loadLessonList();

        // Retry button
        document.getElementById("retry-btn")?.addEventListener("click", () => {
            if (currentLessonId) loadLesson(currentLessonId);
            else loadLessonList();
        });
    </script>
</Layout>

<style>
    /* ─── Nav ─── */
    .dashboard-nav {
        padding: 0.4rem 2rem;
        border-bottom: 1px solid var(--border-color);
        background: rgba(10, 10, 11, 0.6);
        backdrop-filter: blur(12px);
    }

    .nav-container {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 800;
        font-size: 1.25rem;
    }

    .nav-links {
        display: flex;
        gap: 2rem;
    }
    .nav-links a {
        text-decoration: none;
        color: var(--text-secondary);
        font-weight: 500;
        transition: color 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .nav-links a.active {
        color: var(--accent-green);
        font-weight: 600;
    }
    .nav-links a:hover {
        color: var(--text-primary);
    }

    .user-menu {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        font-size: 0.875rem;
    }
    #user-name {
        color: var(--text-secondary);
        font-weight: 500;
    }
    .logout-btn {
        background: rgba(239, 68, 68, 0.1);
        color: var(--accent-red);
        border: 1px solid rgba(239, 68, 68, 0.2);
        padding: 0.5rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-family: inherit;
        font-size: 0.8125rem;
        transition: all 0.2s;
    }
    .logout-btn:hover {
        background: var(--accent-red);
        color: white;
    }

