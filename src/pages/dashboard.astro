---
import Layout from "../layouts/Layout.astro";
import BrandLogo from "../components/BrandLogo.astro";
import MarketTicker from "../components/MarketTicker.astro";
---

<Layout title="Dashboard | DB Portfolios">
<div id="auth-checker" style="display:none;">

    <MarketTicker />

    <!-- ── NAVBAR ── -->
    <nav class="dash-nav">
        <div class="nav-inner">
            <a href="/dashboard" class="nav-logo">
                <BrandLogo width="130" height="22" color="#ffffff" />
            </a>
            <div class="nav-right">
                <span id="user-name" class="nav-user"></span>
                <button id="logout-btn" class="btn-logout">Log Out</button>
            </div>
        </div>
    </nav>

    <!-- ── MAIN (fits viewport, no scroll) ── -->
    <main class="dash-main">

        <!-- Left: greeting + progress -->
        <section class="left-panel">
            <div class="greeting">
                <h1 class="hero-title">Your Learning<br/>Dashboard</h1>
                <p class="hero-sub">Pick up where you left off.</p>
            </div>
            <div class="progress-card glass-card">
                <div class="prog-ring-wrap">
                    <svg class="prog-ring" width="90" height="90" viewBox="0 0 90 90">
                        <circle class="ring-track" cx="45" cy="45" r="34" />
                        <circle class="ring-fill" id="ring-fill" cx="45" cy="45" r="34"
                            stroke-dasharray="213.6" stroke-dashoffset="213.6" />
                    </svg>
                    <div class="prog-center">
                        <span id="prog-pct" class="prog-pct">0%</span>
                        <span class="prog-label">done</span>
                    </div>
                </div>
                <div class="prog-stats">
                    <div class="stat-row">
                        <span class="stat-label">Completed</span>
                        <span class="stat-val" id="stat-done">0 / 2</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Total slides</span>
                        <span class="stat-val">10</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Est. time</span>
                        <span class="stat-val">~10 min</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Right: lesson cards stacked vertically -->
        <section class="lessons-panel">
            <p class="section-title">COURSE LESSONS</p>

            <!-- Lesson 1: Inflation & Compounding -->
            <a href="/lesson-1" class="lesson-card" id="card-1">
                <div class="card-top">
                    <span class="card-badge">Lesson 1</span>
                    <div class="card-icon" id="icon-1">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    </div>
                </div>
                <h3 class="card-title">The Invisible Tax</h3>
                <p class="card-desc">How inflation silently drains savings, why FDs barely help, and how compounding reverses the damage when started early.</p>
                <div class="card-footer">
                    <div class="card-meta">
                        <span class="meta-chip">5 slides</span>
                        <span class="meta-chip">~5 min</span>
                    </div>
                    <span class="start-label" id="start-1">Start lesson →</span>
                </div>
            </a>

            <!-- Lesson 2: Wealth-Growth Hierarchy -->
            <a href="/lesson-2" class="lesson-card" id="card-2">
                <div class="card-top">
                    <span class="card-badge">Lesson 2</span>
                    <div class="card-icon" id="icon-2">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    </div>
                </div>
                <h3 class="card-title">Where to Put Your Money</h3>
                <p class="card-desc">Compare equity, real estate, FDs, and insurance across five criteria — and learn the order to build a resilient portfolio.</p>
                <div class="card-footer">
                    <div class="card-meta">
                        <span class="meta-chip">5 slides</span>
                        <span class="meta-chip">~5 min</span>
                    </div>
                    <span class="start-label" id="start-2">Start lesson →</span>
                </div>
            </a>
        </section>

    </main>
</div>

<script>
    function decodeJwt(token: string) {
        try { return JSON.parse(atob(token.split(".")[1].replace(/-/g,"+").replace(/_/g,"/"))); }
        catch { return null; }
    }
    const token = localStorage.getItem("auth_token");
    if (!token) { window.location.href = "/login"; }
    else {
        (document.getElementById("auth-checker") as HTMLElement).style.display = "block";
        const payload = decodeJwt(token);
        const el = document.getElementById("user-name");
        if (el) el.textContent = payload?.name || payload?.email || "User";
    }
    document.getElementById("logout-btn")?.addEventListener("click", () => {
        localStorage.removeItem("auth_token");
        window.location.href = "/login";
    });

    const done1 = localStorage.getItem("lesson_1_done") === "true";
    const done2 = localStorage.getItem("lesson_2_done") === "true";
    const totalDone = [done1, done2].filter(Boolean).length;
    const pct = Math.round((totalDone / 2) * 100);

    const ringFill = document.getElementById("ring-fill") as SVGCircleElement | null;
    const progPct  = document.getElementById("prog-pct");
    const statDone = document.getElementById("stat-done");
    if (ringFill) {
        const c = 2 * Math.PI * 34;
        ringFill.style.strokeDashoffset = String(c - (c * pct / 100));
    }
    if (progPct)  progPct.textContent  = pct + "%";
    if (statDone) statDone.textContent = `${totalDone} / 2`;

    function markCard(id: string, done: boolean, lockedBy?: boolean) {
        const card  = document.getElementById(`card-${id}`);
        const icon  = document.getElementById(`icon-${id}`);
        const label = document.getElementById(`start-${id}`);
        if (done) {
            card?.classList.add("done");
            if (icon) icon.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>`;
            if (label) label.textContent = "Review →";
        } else if (lockedBy === false) {
            card?.classList.add("locked");
            if (label) label.textContent = "Complete Lesson 1 first";
        }
    }
    markCard("1", done1);
    markCard("2", done2, done1);
</script>
</Layout>

<style>
/* ── Nav ── */
.dash-nav {
    height: 48px;
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
    background: rgba(10,10,11,0.8);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border-color);
}
.nav-inner {
    width: 100%; max-width: 1080px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
}
.nav-logo { display:flex; align-items:center; text-decoration:none; }
.nav-right { display:flex; align-items:center; gap:1rem; }
.nav-user { font-size:0.8rem; color:var(--text-secondary); font-weight:500; }
.btn-logout {
    background:transparent; color:var(--accent-red);
    border:1px solid rgba(239,68,68,0.3);
    padding:0.3rem 0.8rem; border-radius:8px;
    cursor:pointer; font-family:inherit; font-size:0.78rem; font-weight:600;
    transition:all 0.2s;
}
.btn-logout:hover { background:var(--accent-red); color:#fff; }

/* ── Main: two-column, fills remaining viewport ── */
.dash-main {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.5rem;
    max-width: 1080px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    /* Fill exactly the remaining height after ticker + nav */
    height: calc(100vh - 30px - 48px); /* 30px ticker, 48px nav */
    box-sizing: border-box;
    align-items: start;
}

/* ── Left panel ── */
.left-panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
}
.greeting { }
.hero-title {
    font-size: 1.6rem;
    font-weight: 800;
    margin: 0 0 0.3rem;
    line-height: 1.25;
    background: linear-gradient(135deg, #fff 0%, #94a3b8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.hero-sub { margin:0; font-size:0.875rem; color:var(--text-secondary); }

.progress-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    flex-shrink: 0;
}
.prog-ring-wrap { position:relative; flex-shrink:0; }
.prog-ring { transform:rotate(-90deg); }
.ring-track { fill:none; stroke:rgba(255,255,255,0.07); stroke-width:6; }
.ring-fill {
    fill:none; stroke:var(--accent-green); stroke-width:6; stroke-linecap:round;
    transition:stroke-dashoffset 1s cubic-bezier(0.4,0,0.2,1);
}
.prog-center {
    position:absolute; inset:0; display:flex; flex-direction:column;
    align-items:center; justify-content:center;
}
.prog-pct { font-size:1rem; font-weight:800; color:#fff; line-height:1; }
.prog-label { font-size:0.6rem; color:var(--text-secondary); }
.prog-stats { display:flex; flex-direction:column; gap:0.4rem; flex:1; }
.stat-row { display:flex; justify-content:space-between; align-items:center; }
.stat-label { font-size:0.75rem; color:var(--text-secondary); }
.stat-val { font-size:0.8rem; font-weight:700; color:#fff; }

/* ── Lessons panel ── */
.lessons-panel {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
}
.section-title {
    font-size:0.68rem; font-weight:700; letter-spacing:0.1em;
    color:var(--text-secondary); margin:0;
}

/* ── Card ── */
.lesson-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.1rem 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    text-decoration: none;
    color: var(--text-primary);
    backdrop-filter: blur(16px);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
    flex: 1; /* fill equal height */
}
.lesson-card::before {
    content:''; position:absolute; inset:0;
    background:linear-gradient(135deg, rgba(16,185,129,0.05) 0%, transparent 60%);
    opacity:0; transition:opacity 0.3s;
}
.lesson-card:hover:not(.locked) {
    border-color:rgba(16,185,129,0.4);
    transform:translateY(-2px);
    box-shadow:0 10px 30px rgba(16,185,129,0.08);
}
.lesson-card:hover:not(.locked)::before { opacity:1; }
.lesson-card.done { border-color:rgba(16,185,129,0.3); }
.lesson-card.locked { opacity:0.45; pointer-events:none; }

.card-top { display:flex; align-items:center; justify-content:space-between; }
.card-badge {
    font-size:0.65rem; font-weight:700; letter-spacing:0.08em;
    text-transform:uppercase; color:var(--accent-green);
    background:rgba(16,185,129,0.12); border-radius:5px;
    padding:0.2rem 0.5rem;
}

.card-icon {
    width:30px; height:30px; border-radius:50%;
    background:rgba(255,255,255,0.05); border:1px solid var(--border-color);
    display:flex; align-items:center; justify-content:center;
    color:var(--text-secondary); transition:all 0.2s;
}
.lesson-card.done .card-icon { background:rgba(16,185,129,0.15); border-color:var(--accent-green); color:var(--accent-green); }
.lesson-card:hover:not(.locked) .card-icon { border-color:var(--accent-green); color:var(--accent-green); }

.card-title { font-size:1rem; font-weight:700; margin:0; line-height:1.3; }
.card-desc { font-size:0.82rem; color:var(--text-secondary); margin:0; line-height:1.55; flex:1; }

.card-footer { display:flex; align-items:center; justify-content:space-between; margin-top:auto; padding-top:0.5rem; border-top:1px solid var(--border-color); }
.card-meta { display:flex; gap:0.4rem; }
.meta-chip {
    font-size:0.7rem; color:var(--text-secondary);
    background:rgba(255,255,255,0.04); border:1px solid var(--border-color);
    border-radius:20px; padding:0.15rem 0.5rem;
}
.start-label { font-size:0.8rem; font-weight:600; color:var(--accent-green); }
.lesson-card.done .start-label { color:var(--text-secondary); }

@media (max-width: 700px) {
    .dash-main {
        grid-template-columns: 1fr;
        height: auto;
        overflow-y: auto;
    }
}
</style>
